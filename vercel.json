{
  "version": 2,
  "builds": [
    {
      "src": "pages/**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/pages/(.*)", "dest": "/pages/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/(.*)", "dest": "/pages/vehicle.html" }
  ]
}
